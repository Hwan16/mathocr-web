# Server-side Claude model policy. Keep this value in the allowlist below.
# Allowed: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# 프로모션 코드 (콤마 구분, 대소문자 무시). 일치 시 +100 보너스 크레딧
PROMO_CODES=2026ocrbeta

# Rate limiter 공유 저장소 (T3) — Upstash Redis REST 자격증명.
# console.upstash.com → Redis DB 생성 → REST API 탭에서 복사.
# 미설정 시 인스턴스 메모리 방식으로 폴백 (기능은 동작하나 서버리스에서 카운트 리셋됨)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 관리자 대시보드 AI 비용 조회용 (선택)
# Anthropic Console → Settings → Admin keys에서 생성 (sk-ant-admin..., 조직 계정 필요)
ANTHROPIC_ADMIN_KEY=
# Mathpix 건당 단가(USD) — 대시보드 예상 비용 계산용. 미설정 시 0.002
MATHPIX_COST_PER_REQUEST=0.002
